def active_area_report(filename, status):
    data = read_csv(filename)
    summary = {}
    
    for alarm in data: 
        if alarm["status"] == status:
            area  = alarm["area"]
            if area not in summary:
                summary[area] = 0
            summary[area] += 1
    
    res = []
    for new in summary:
        res.append({
            "area" : new,
            "count" : summary[new]
        })
        
    res.sort(key=lambda item:item["area"], reverse=True)
        
    return res
            
def status_report(filename):
    data = read_csv(filename)
    summary = {}
    
    for alarm in data:
        status = alarm["status"]
        
        if status not in summary:
            summary[status] = 0
        summary[status] += 1
    
    res = []
    for new in summary:
        res.append({
            "status" : new,
            "count" : summary[new]
        })
    
    res.sort(key=lambda item:item["count"], reverse=True)

    return res
