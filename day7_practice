import csv


def rafc(filename):
    res = []
    
    with open(filename, newline= "") as file:
        reader  = csv.DictReader(file)
        
        for row in reader: 
            res.append(row)
            
    return res



def gstfc():
    new = rafc("alarms.csv")
    get_tag = []
    
    for al in new:
        get_tag.append(al["tag"])
    
    get_tag.sort()        
    
    return get_tag

print(gstfc())    
        


